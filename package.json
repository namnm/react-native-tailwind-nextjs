{
  "name": "react-native-tailwind-nextjs",
  "version": "0.0.0-locked",
  "author": "nongdan.dev",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "lint": "pnpm doctoc && pnpm normalize && pnpm eslint && pnpm stylelint && pnpm prettier",
    "doctoc": "doctoc --loglevel warn --github README.md",
    "normalize": "node ./devtools normalize",
    "eslint": "node ./devtools eslint",
    "stylelint": "node ./devtools stylelint",
    "prettier": "node ./devtools prettier",
    "ts": "node ./devtools ts"
  },
  "engines": {
    "node": ">=24.11",
    "pnpm": ">=10"
  },
  "dependencies": {
    "json5": "2.2.3",
    "tsconfig-paths": "4.2.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "doctoc": "2.4.1",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "overrides": {
      "@react-navigation/native": "7.2.2",
      "@react-navigation/native-stack": "7.14.11",
      "react": "19.2.3",
      "react-native": "0.85.2",
      "react-native-fast-image": "8.6.3",
      "react-native-mmkv": "4.3.1",
      "react-native-nitro-modules": "0.35.5",
      "react-native-reanimated": "4.3.0",
      "react-native-safe-area-context": "5.7.0",
      "react-native-screens": "4.24.0",
      "react-native-svg": "15.15.4",
      "react-native-worklets": "0.8.1"
    },
    "patchedDependencies": {
      "react-native-web": "patches/react-native-web.patch",
      "eslint-plugin-import": "patches/eslint-plugin-import.patch"
    }
  }
}
